APP_NAME=PRIMO-Optimizer
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173
PYTHON_API_URL=

MONGODB_URI='mongodb://127.0.0.1:27017/'
MONGODB_USERNAME=user
MONGODB_PASSWORD=pass
MONGODB_DATABASE=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_APP_NAME='PRIMO Web App'

# Users who should receive notifications of failed tasks
TASK_EMAIL_ADMINS=user1@example.com,user2@example.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Comma separated list of origins allowed to make requests to this API
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Only enable Log viewer for local until authorization is added
LOG_VIEWER_ENABLED=true

# Only relevant for initial seeding
OAUTH_CLIENT_ID=

DATA_UPLOAD_DIRECTORY_PATH='/var/www/netl-mwu/netl-mwu/storage/app/tmp/'
SHARED_STORAGE_PATH='' # Base path to python storage/app/tmp directory to simulate share storage of server on uploads
