{
    "printWidth": 120,

    "tabWidth": 4,

    "singleQuote": true,

    "quoteProps": "as-needed",

    "jsxSingleQuote": false,

    "trailingComma": "none",

    "bracketSpacing": true,

    "bracketSameLine": false,

    "arrowParens": "always",

    "requirePragma": false,

    "insertPragma": false,

    "proseWrap": "preserve",

    "htmlWhitespaceSensitivity": "css",

    "vueIndentScriptAndStyle": true,

    "endOfLine": "lf",

    "embeddedLanguageFormatting": "auto",

    "singleAttributePerLine": false
}